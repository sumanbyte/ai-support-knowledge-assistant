// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

generator jsonSchema {
  provider                 = "prisma-json-schema-generator"
  output                   = "../generated/json-schema"
  keepRelationFields       = "false"
  keepRelationScalarFields = "true"
  includeRequiredFields    = "true"
}

datasource db {
  provider = "postgresql"
}

enum DocumentStatus {
  PROCESSING
  INDEXED
  ERROR
}

enum DocumentIcon {
  PICTURE_AS_PDF
  DESCRIPTION
  MARKDOWN
  CODE
  SLIDESHOW
  YAML
}

model User {
  id               String             @id @default(uuid())
  email            String             @unique
  name             String
  password         String?
  googleId         String?            @unique
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  documents        Document[]
  chats            Chat[]
  pipelineLogs     PipelineLog[]
  retrievalMetrics RetrievalMetrics[]
}

model Document {
  id        String         @id @default(uuid())
  publicId  String         @unique
  name      String
  size      Float
  dept      String
  status    DocumentStatus @default(PROCESSING)
  chunks    Int
  icon      DocumentIcon
  url       String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  userId    String
  user      User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("documents")
}

model RagMetrics {
  id      String  @id @default(uuid())
  success Boolean

  type String @default("heartbeat")

  queryLatencyMS Float?   @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([createdAt])
  @@map("rag_metrics")
}

model RetrievalMetrics {
  id        String   @id @default(uuid())
  score     Float
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, score])
  @@map("retrieval_metrics")
}

enum ChatMessageRole {
  USER
  ASSISTANT
}

model Chat {
  id           String        @id @default(uuid())
  name         String        @default("Untitled Chat")
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatMessages ChatMessage[]

  @@index([userId])
  @@map("chats")
}

model ChatMessage {
  id        String          @id @default(uuid())
  chatId    String
  chat      Chat            @relation(fields: [chatId], references: [id], onDelete: Cascade)
  content   String
  role      ChatMessageRole
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([chatId])
  @@map("chat_messages")
}

enum PipelineLogType {
  info
  success
  warn
  error
  system
}

model PipelineLog {
  id        String          @id @default(uuid())
  timestamp DateTime        @default(now())
  message   String
  type      PipelineLogType
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([createdAt])
  @@map("pipeline_logs")
}
