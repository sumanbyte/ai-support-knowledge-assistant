  "info": {
    "title": "Converse AI API",
    "description": "Enterprise knowledge assistant API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "CreateUploadDto": {
        "type": "object",
        "properties": {}
      },
      "UploadedFileInfoDto": {
        "type": "object",
        "properties": {
          "publicId": {
            "type": "string",
            "description": "Public ID"
          },
          "url": {
            "type": "string",
            "description": "URL"
          },
          "format": {
            "type": "string",
            "description": "Format"
          },
          "bytes": {
            "type": "number",
            "description": "Bytes"
          }
        },
        "required": [
          "publicId",
          "url",
          "format",
          "bytes"
        ]
      },
      "UploadResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Success"
          },
          "message": {
            "type": "string",
            "description": "Message"
          },
          "file": {
            "description": "File",
            "allOf": [
              {
                "$ref": "#/components/schemas/UploadedFileInfoDto"
              }
            ]
          }
        },
        "required": [
          "success",
          "message",
          "file"
        ]
      },
      "UpdateUploadDto": {
        "type": "object",
        "properties": {}
      },
      "DocumentDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "publicId": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "size": {
            "type": "string"
          },
          "dept": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PROCESSING",
              "INDEXED",
              "ERROR"
            ],
            "default": "PROCESSING"
          },
          "chunks": {
            "type": "number"
          },
          "icon": {
            "type": "string",
            "enum": [
              "PICTURE_AS_PDF",
              "DESCRIPTION",
              "MARKDOWN",
              "CODE",
              "SLIDESHOW",
              "YAML"
            ]
          },
          "url": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "userId": {
            "type": "string"
          }
        },
        "required": [
          "publicId",
          "name",
          "size",
          "dept",
          "chunks",
          "icon",
          "url",
          "updatedAt",
          "userId"
        ]
      },
      "DeleteResponseDto": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "description": "Success"
          },
          "message": {
            "type": "string",
            "description": "Message"
          },
          "data": {
            "description": "Data",
            "allOf": [
              {
                "$ref": "#/components/schemas/DocumentDto"
              }
            ]
          }
        },
        "required": [
          "success",
          "message",
          "data"
        ]
      },
      "CreateChatDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateChatDto": {
        "type": "object",
        "properties": {}
      },
      "ChatSourceDto": {
        "type": "object",
        "properties": {
          "citationNumber": {
            "type": "number"
          },
          "matchScore": {
            "type": "number"
          },
          "fileName": {
            "type": "string"
          },
          "cloudinaryUrl": {
            "type": "string"
          },
          "documentId": {
            "type": "string"
          },
          "numberOfPages": {
            "type": "number"
          },
          "snippet": {
            "type": "string"
          }
        },
        "required": [
          "citationNumber",
          "matchScore",
          "fileName",
          "cloudinaryUrl",
          "documentId",
          "numberOfPages",
          "snippet"
        ]
      },
      "ChatResponseDto": {
        "type": "object",
        "properties": {
          "chatId": {
            "type": "string"
          },
          "success": {
            "type": "boolean"
          },
          "response": {
            "type": "string"
          },
          "sources": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatSourceDto"
            }
          }
        },
        "required": [
          "chatId",
          "success",
          "response",
          "sources"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {}
      },
      "SignupDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@company.com"
          },
          "name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "minLength": 8,
            "maxLength": 16
          }
        },
        "required": [
          "email",
